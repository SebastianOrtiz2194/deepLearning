# Kafka bootstrap servers (comma-separated for clusters)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379

# Inference Service HTTP port
SERVER_PORT=8080

# Spring active profiles: dev, prod, stub
# stub — uses StubInferenceEngine (no model download, deterministic results)
# dev  — verbose logging, optional stub engine
# prod — real DJL engine, info-level logging
SPRING_PROFILES_ACTIVE=prod
